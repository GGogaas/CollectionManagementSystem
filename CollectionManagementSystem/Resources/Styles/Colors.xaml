<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    
    <Color x:Key="AppPrimary">#2563EB</Color>
    <Color x:Key="AppPrimaryDark">#1D4ED8</Color>
    <Color x:Key="AppPrimaryLight">#DBEAFE</Color>
    <Color x:Key="AppAccent">#F59E0B</Color>
    <Color x:Key="AppAccentDark">#D97706</Color>
    <Color x:Key="AppAccentLight">#FEF3C7</Color>
    <Color x:Key="AppSuccess">#10B981</Color>
    <Color x:Key="AppSuccessLight">#D1FAE5</Color>
    <Color x:Key="AppDanger">#EF4444</Color>
    <Color x:Key="AppDangerLight">#FEE2E2</Color>
    <Color x:Key="AppPurple">#8B5CF6</Color>
    <Color x:Key="AppPurpleLight">#EDE9FE</Color>

    <Color x:Key="AppBackground">#F1F5F9</Color>
    <Color x:Key="AppSurface">#FFFFFF</Color>
    <Color x:Key="AppText">#1E293B</Color>
    <Color x:Key="AppTextSecondary">#64748B</Color>
    <Color x:Key="AppBorder">#E2E8F0</Color>
    <Color x:Key="AppSold">#94A3B8</Color>

    
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#F59E0B</Color>
    <Color x:Key="SecondaryDarkText">#1E293B</Color>
    <Color x:Key="Tertiary">#10B981</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#1D4ED8</Color>
    <Color x:Key="OffBlack">#1E293B</Color>
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray900">#1E293B</Color>
    <Color x:Key="Gray950">#0F172A</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource AppPrimary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource AppAccent}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource AppSuccess}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
